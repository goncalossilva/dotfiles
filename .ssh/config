Include ~/.orbstack/ssh/config

Host *
   IgnoreUnknown UseKeychain
   UseKeychain yes

Host 192.168.*.*
   StrictHostKeyChecking no
   UserKnownHostsFile=/dev/null

Host 10.*.*.*
   StrictHostKeyChecking no
   UserKnownHostsFile=/dev/null

Host console-*
    UserKnownHostsFile /tmp/ephemeral-console-host-keys
    StrictHostKeyChecking accept-new
